default_platform(:ios)

def app_store_connect_api_key_from_env
  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
    key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"),
    is_key_content_base64: true
  )
end

def bump_build_number
  if ENV["BUILD_NUMBER"]
    increment_build_number(
      xcodeproj: "RouteTrace.xcodeproj",
      build_number: ENV["BUILD_NUMBER"]
    )
  else
    increment_build_number(xcodeproj: "RouteTrace.xcodeproj")
  end
end

def export_options
  "ExportOptions.plist"
end

platform :ios do
  desc "Archive and export an App Store IPA (no upload)"
  lane :build do
    setup_ci if ENV["CI"]
    bump_build_number

    build_app(
      scheme: "RouteTrace",
      export_method: "app-store",
      export_options: export_options,
      xcargs: "-allowProvisioningUpdates"
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]
    api_key = app_store_connect_api_key_from_env
    bump_build_number

    build_app(
      scheme: "RouteTrace",
      export_method: "app-store",
      export_options: export_options,
      xcargs: "-allowProvisioningUpdates",
      api_key: api_key
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
